# =============================================================================
# OpenClaw Agent Server — Environment Configuration
# Rename this file to .env and fill in values before starting.
# =============================================================================

# --- Telegram ---
# One bot token per persona. Get from @BotFather.
TELEGRAM_TOKEN_PROTOTYPE=your-prototype-bot-token-here
TELEGRAM_TOKEN_AUTOMATE=your-automate-bot-token-here
TELEGRAM_TOKEN_RESEARCH=your-research-bot-token-here

# Your Telegram user ID. Only messages from this ID are accepted.
# Find yours by messaging @userinfobot on Telegram.
OPERATOR_TELEGRAM_ID=123456789

# Webhook secret — random string you choose, must match what you register with Telegram
WEBHOOK_SECRET=change-this-to-a-random-string

# --- PostgreSQL ---
# Matches docker-compose.yml: service=postgres, db=openclaw, user=openclaw
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=changeme

# --- Ollama ---
# Service name from docker-compose.yml
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# Default local model. Change to whatever you have pulled.
OLLAMA_DEFAULT_MODEL=mistral-nemo

# --- OpenRouter (cloud escalation) ---
# Leave blank until you have an OpenRouter account. Cloud path disables itself.
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# --- Agent Behavior ---
CIRCUIT_BREAKER_MAX_CALLS=10
CIRCUIT_BREAKER_WINDOW_SECONDS=60
CONTEXT_TRIM_TOKENS=8000
COST_ESCALATION_THRESHOLD_USD=1.00
DEFAULT_BUDGET_CEILING_TOKENS=50000

# Quiet hours (24h, local time). Approval requests queue during this window.
QUIET_HOURS_START=19
QUIET_HOURS_END=7

# Heartbeat timeout for long-running task monitoring (ADR-037, seconds)
AGENT_HEARTBEAT_TIMEOUT_SECONDS=7200
